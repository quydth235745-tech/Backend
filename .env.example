# Backend server
NODE_ENV=production
PORT=3000

# Database
MONGODB_URI=mongodb://nphuquy260_db_user:123@ac-yolp8dr-shard-00-02.k31dl8m.mongodb.net:27017/food-order?ssl=true&authSource=admin

# Auth
JWT_SECRET=replace_with_a_long_random_secret

# CORS (frontend domain)
FRONTEND_URL=https://your-frontend.vercel.app
# Optional: comma-separated list when you have multiple frontend domains
FRONTEND_URLS=https://your-frontend.vercel.app,https://www.your-frontend.vercel.app
# Optional (production): allow https://*.vercel.app preview domains
CORS_ALLOW_VERCEL_PREVIEWS=true
# Optional (production): restrict preview allowance to one Vercel project name
# Example for https://my-app-abc123.vercel.app => my-app
VERCEL_PROJECT_NAME=
# Optional (development only): allow all browser origins while testing locally
CORS_DEV_ALLOW_ALL=false

# Cloudinary (optional if you upload images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional if you send emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
